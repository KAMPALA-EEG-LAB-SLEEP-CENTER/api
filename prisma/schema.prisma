generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(ADMIN)
  status    AdminStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  otpCodes  OtpCode[]
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model Appointment {
  id               String            @id @default(uuid())
  fullName         String
  dateOfBirth      DateTime
  gender           String
  phoneNumber      String
  email            String
  service          ServiceType
  preferredDate    DateTime
  preferredTime    String
  symptoms         String[]
  symptomDetails   String?
  medications      String?
  status           AppointmentStatus @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  referralFilePath String?
}

enum ServiceType {
  EEG_TEST
  SLEEP_STUDY
  DEPRESSION_SCREEN
  OTHER_CONSULTATION
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model OtpCode {
  id        String   @id @default(uuid())
  code      String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}